# --- Supabase (Settings > API dans le dashboard Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Chaîne de connexion Postgres — utilisée UNIQUEMENT par les migrations
# (npm run db:migrate). L'app, elle, passe par l'API Supabase (pas de pool requis).
# Dans le dashboard : Connect > Connection String > prendre l'URI "Session pooler"
# (port 5432, hôte *.pooler.supabase.com — compatible IPv4).
# Éviter le "Transaction pooler" (6543) et la connexion directe (IPv6 seulement).
DATABASE_URL=postgresql://postgres:MOT_DE_PASSE@db.xxxxxxxxxxxx.supabase.co:5432/postgres
# Alternative si la connexion directe échoue (réseau sans IPv6) :
# DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:MOT_DE_PASSE@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- Application ---
# URL publique de l'app (sous-domaine). Les QR dynamiques pointent vers <APP_URL>/q/<slug>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- PayDunya (Intégrations > Clés API) ---
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
# "test" (sandbox) ou "live"
PAYDUNYA_MODE=test

# --- Sentry (suivi d'erreurs, sentry.io) ---
# DSN : Sentry → Settings du projet → Client Keys (DSN). Pas secret (public par nature).
NEXT_PUBLIC_SENTRY_DSN=
# Auth token build-time (upload des source maps) : Sentry → Settings → Auth Tokens.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
